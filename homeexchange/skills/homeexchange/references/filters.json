{
  "exchange_types": {
    "field": "calendar.exchange_types",
    "type": "array",
    "description": "Which types of home exchange to include",
    "values": [
      { "value": "guest-wanted", "label": "GuestPoints only — you pay in GuestPoints, no swap required" },
      { "value": "reciprocal",   "label": "Reciprocal only — home swap, host visits you in return" },
      { "value": "available",    "label": "Either — GuestPoints or reciprocal" }
    ]
  },

  "flexibility": {
    "field": "calendar.flexibility",
    "type": "integer",
    "description": "Days of flexibility either side of the requested dates (0 = exact dates)"
  },

  "guestpoints": {
    "field": "search_query.guestpoints",
    "type": "object",
    "description": "GuestPoints per night budget range",
    "fields": {
      "from": "minimum GP/night",
      "to":   "maximum GP/night"
    }
  },

  "size": {
    "field": "home.size",
    "type": "object",
    "description": "Guest count and minimum room requirements",
    "fields": {
      "beds.adults":  "number of adult beds needed",
      "beds.babies":  "number of baby/child beds needed",
      "bedrooms":     "minimum number of bedrooms",
      "bathrooms":    "minimum number of bathrooms"
    }
  },

  "is_private_room": {
    "field": "home.is_private_room",
    "type": "boolean",
    "description": "false = entire home only; true = private room in shared home also OK"
  },

  "amenities": {
    "field": "home.amenities",
    "type": "array",
    "description": "Must-have amenities — only homes with ALL selected amenities are returned",
    "groups": {
      "family": [
        { "value": "baby-bed",          "label": "Baby bed" },
        { "value": "kids-toys",         "label": "Kids' toys" },
        { "value": "playground",        "label": "Kids' playground" },
        { "value": "baby-gear",         "label": "Baby gear" },
        { "value": "secured-pool",      "label": "Secured/fenced pool" }
      ],
      "accessibility": [
        { "value": "children-welcome",  "label": "Children welcome" },
        { "value": "pets-welcome",      "label": "Pets welcome" },
        { "value": "smokers-welcome",   "label": "Smokers welcome" },
        { "value": "disabled-access",   "label": "Wheelchair accessible" }
      ],
      "remote_work": [
        { "value": "dedicated-workspace",   "label": "Dedicated workspace" },
        { "value": "high-speed-connexion",  "label": "High-speed internet" }
      ],
      "basics": [
        { "value": "heating-system",    "label": "Heating" },
        { "value": "dishwasher",        "label": "Dishwasher" },
        { "value": "washing-machine",   "label": "Washing machine" },
        { "value": "dryer",             "label": "Dryer" },
        { "value": "bathtub",           "label": "Bathtub" },
        { "value": "tv",                "label": "TV" },
        { "value": "wifi",              "label": "WiFi" },
        { "value": "electric-car-plug", "label": "EV charging" }
      ],
      "premium": [
        { "value": "a-c",               "label": "Air conditioning" },
        { "value": "elevator",          "label": "Elevator" },
        { "value": "parking-space",     "label": "Private parking" },
        { "value": "jacuzzi",           "label": "Jacuzzi" },
        { "value": "fireplace",         "label": "Fireplace" },
        { "value": "gym",               "label": "Private gym" },
        { "value": "garden",            "label": "Garden" },
        { "value": "balcony-terrace",   "label": "Balcony or terrace" },
        { "value": "bbq",               "label": "BBQ" },
        { "value": "swimming-pool",     "label": "Swimming pool" },
        { "value": "bicycle",           "label": "Bicycle available" },
        { "value": "car",               "label": "Car available" },
        { "value": "cleaning-person",   "label": "Cleaning person" }
      ],
      "location": [
        { "value": "public-transit-access", "label": "Public transport access" }
      ]
    }
  },

  "surrounding": {
    "field": "home.surrounding",
    "type": "array",
    "description": "Character of the home's surroundings — pick one or more",
    "values": [
      { "value": "seaside",      "label": "Seaside / coastal" },
      { "value": "countryside",  "label": "Countryside" },
      { "value": "mountains",    "label": "Mountains" },
      { "value": "cities",       "label": "City" },
      { "value": "villages",     "label": "Village" },
      { "value": "isolated",     "label": "Isolated / remote" },
      { "value": "island",       "label": "Island" },
      { "value": "lakes",        "label": "Lakes" }
    ]
  },

  "exclude_animals": {
    "field": "home.exclude_animals",
    "type": "array",
    "description": "Exclude homes that have these animals (for allergy reasons)",
    "values": [
      { "value": "cat",   "label": "Cats" },
      { "value": "dog",   "label": "Dogs" },
      { "value": "other", "label": "Other animals" }
    ]
  },

  "eco_level": {
    "field": "home.eco_level",
    "type": "integer",
    "description": "Minimum eco-friendliness level (homes with at least N eco amenities)",
    "values": [
      { "value": 1, "label": "No restriction" },
      { "value": 2, "label": "Some eco features" },
      { "value": 3, "label": "Mostly eco-friendly" },
      { "value": 4, "label": "Fully sustainable (solar panels, low-consumption appliances, etc.)" }
    ]
  },

  "filters": {
    "field": "search_query.filters",
    "type": "array",
    "description": "Boolean quality flags — include the string to enable the filter",
    "values": [
      { "value": "home-verified",                 "label": "Verified homes only" },
      { "value": "response-rate-above-threshold", "label": "Responsive hosts only (average response rate or higher)" },
      { "value": "no-bed-up",                     "label": "No loft/temporary beds — only permanent sleeping arrangements" }
    ]
  },

  "favorite": {
    "field": "search_query.favorite",
    "type": "boolean",
    "description": "true = show only homes you've marked as favourites"
  },

  "reverse": {
    "field": "search_query.reverse",
    "type": "array",
    "description": "Show homes belonging to members who added your home to their travel wishlist. Pass your home ID(s)."
  },

  "extended": {
    "field": "search_query.extended",
    "type": "boolean",
    "description": "Broadens the search area slightly beyond the selected location bounds"
  },

  "location": {
    "field": "search_query.location",
    "type": "object",
    "description": "Two mutually exclusive formats — use bounds (preferred) when a radius was given, polygon otherwise",
    "formats": {
      "bounds": {
        "description": "Bounding box — preferred; compute via bounds-from-place.sh <place> <radius_km>",
        "fields": {
          "ne.lat": "northeast corner latitude",
          "ne.lon": "northeast corner longitude",
          "sw.lat": "southwest corner latitude",
          "sw.lon": "southwest corner longitude"
        }
      },
      "polygon": {
        "description": "Named-region polygon from Jawg — fallback when no radius given",
        "fields": {
          "location_id": "Jawg location id (openstreetmap:LAYER:relation/ID or whosonfirst:LAYER:ID)",
          "provider": "always 'Jawg'"
        }
      }
    }
  }
}
